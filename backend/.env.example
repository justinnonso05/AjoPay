MONNIFY_CONTRACT_CODE="<your_monnify_contract_code>"
MONNIFY_WALLET_ACCOUNT="<your_monnify_wallet_account>"
MONNIFY_DEFAULT_PREFERRED_BANK="232"

BREVO_API_KEY="<your_brevo_api_key>"
EMAIL_DOMAIN="<your_verified_email_domain>"

SCHEDULER_INTERVAL_MINUTES=5
GEMINI_API_KEY="<your_gemini_api_key>"
CLOUDINARY_CLOUD_NAME="<your_cloudinary_cloud_name>"
CLOUDINARY_API_KEY="<your_cloudinary_api_key>"
CLOUDINARY_API_SECRET="<your_cloudinary_api_secret>"

PAYAJO_PLATFORM_FEE_PERCENT=1
MONNIFY_COLLECTION_FEE_CAP=2000 
